# Plantilla de variables de entorno. COPIAR a `.env` para pruebas locales.
# NUNCA commitear el `.env` real (ya está en .gitignore).
# En producción (la Routine de Claude Code), estos valores se cargan como
# variables de entorno / secretos en la UI web, NO en un archivo.

# --- Telegram (IMPRESCINDIBLE) ---
# Token que te da @BotFather al crear el bot.
TELEGRAM_BOT_TOKEN=
# Tu chat_id numérico (el de Juan), para que yo sepa a quién escribirle.
TELEGRAM_CHAT_ID=

# --- Twitter / X (IMPRESCINDIBLE) ---
# Las 4 credenciales de la app del Developer Portal, con permiso Read+Write.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- OpenAI (OPCIONAL / DIFERIDO: solo para transcribir notas de voz) ---
OPENAI_API_KEY=

# --- Anthropic (NO necesaria para v1; solo si algún script hace llamadas
#     programáticas a Claude por fuera de mi propio razonamiento) ---
# ANTHROPIC_API_KEY=
